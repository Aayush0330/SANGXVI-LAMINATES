generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  MANAGER
  ACCOUNTANT
  DISPATCH_TEAM
  ORDER_TEAM
  QC_TEAM
  DRIVER_TRANSPORT
  COLLECTION_TEAM
  SALES_FIELD_TEAM
  DEALER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  FORMER_EMPLOYEE
}

enum GeofenceMode {
  OFFICE_REQUIRED
  ANYWHERE
}

enum ProductStatus {
  AVAILABLE
  LOW_STOCK
  OUT_OF_STOCK
}

enum InventoryInquiryStatus {
  NEW_INQUIRY
  FOLLOW_UP
  ORDER_PLACED
  NOT_IN_STOCK
  MISSED_SALE
  CLOSED
}

enum FieldVisitStatus {
  VISIT_REPORTED
  GOAL_ACHIEVED
  GOAL_PENDING
  FOLLOW_UP_REQUIRED
  CLOSED
}

enum CollectionStatus {
  ASSIGNED
  ON_THE_WAY
  REACHED
  PARTIALLY_COLLECTED
  COLLECTED
  FAILED
  RESCHEDULED
  VERIFIED
  CANCELLED
}

enum CollectionPaymentMode {
  CASH
  CHEQUE
  UPI
  BANK_TRANSFER
  OWNER_COLLECTED
  OTHER
}

enum AttendanceRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AttendanceLeaveType {
  FULL_DAY
  HALF_DAY
  PAID
  UNPAID
  EMERGENCY
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  TEMPORARY
}

enum EmployeeLifecycleType {
  JOINED
  PROFILE_UPDATED
  TRANSFERRED
  PROMOTED
  STATUS_CHANGED
  EXITED
  REACTIVATED
  NOTE
}

enum PayrollPaymentStatus {
  PENDING
  PROCESSING
  PAID
  ON_HOLD
  FAILED
}

enum WorkTeamMemberRole {
  LEAD
  MEMBER
}

enum WorkTeamType {
  GENERAL
  PHYSICAL_DISPATCH
}

enum PhysicalCheckStatus {
  ASSIGNED
  IN_PROGRESS
  READY_FOR_QC
  ISSUE_REPORTED
  QC_REWORK
  COMPLETED
  CANCELLED
}

enum PhysicalCheckIssueType {
  SHORT_QUANTITY
  DAMAGED_PRODUCT
  WRONG_PRODUCT
  QUANTITY_MISMATCH
  PRODUCT_UNAVAILABLE
  OTHER
}

enum WorkTaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  BLOCKED
  DONE
  CANCELLED
}

enum WorkTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
  CRITICAL
}

enum OrderSource {
  DEALER_PORTAL
  WALK_IN
  PHONE
  WHATSAPP
  MANUAL_ENTRY
  SALES_FIELD
}

enum OrderItemPriceSource {
  DEALER_PRICE
  SELLING_PRICE
  MANUAL_PRICE
  LEGACY_BACKFILL
}


enum PurchaseRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  ORDERED
  IN_TRANSIT
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
  CANCELLED
}

enum PurchaseRequestPriority {
  NORMAL
  HIGH
  URGENT
}

enum OrderStatus {
  NEW_ORDER
  PENDING_TEAM_ASSIGNMENT
  PHYSICAL_CHECK_ASSIGNED
  PHYSICAL_CHECK_IN_PROGRESS
  PHYSICAL_CHECK_ISSUE
  QC_REWORK
  PENDING_STOCK_CHECK
  STOCK_CHECKED
  STOCK_BLOCKED
  BACKORDERED
  PENDING_QC
  READY_FOR_DISPATCH
  QC_APPROVED
  CANCELLATION_REQUESTED
  TRANSPORT_ASSIGNED
  ON_THE_WAY
  DELIVERED
  INVOICE_UPLOADED
  CANCELLED
}

enum DeliveryProofAssistanceStatus {
  NOT_REQUESTED
  REQUESTED
  COMPLETED
  CANCELLED
}

enum DeliveryProofUploadMode {
  DRIVER_SELF
  MANAGER_ASSISTED
  INTERNAL_UPLOAD
}

enum SecurityEventType {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  ACCESS_DENIED
  PASSWORD_RESET
  PASSWORD_CHANGED
  USER_CREATED
  USER_UPDATED
  USER_STATUS_CHANGED
  USER_ROLE_CHANGED
  DEALER_MEMBER_CREATED
  DEALER_MEMBER_UPDATED
  DEALER_MEMBER_DELETED
  DEALER_PROFILE_CREATED
  DEALER_PROFILE_UPDATED
  DEALER_ARCHIVED
  DEALER_REACTIVATED
  INTERNAL_DEALER_ORDER_CREATED
  FIRST_OWNER_CREATED
  OFFICE_LOCATION_UPDATED
  ATTENDANCE_PUNCH
  ATTENDANCE_BREAK
  ATTENDANCE_BLOCKED
  ATTENDANCE_PAY_PROFILE_UPDATED
  ATTENDANCE_ADVANCE_REQUESTED
  ATTENDANCE_ADVANCE_APPROVED
  ATTENDANCE_ADVANCE_REJECTED
  ATTENDANCE_LEAVE_REQUESTED
  ATTENDANCE_OWNER_UNAVAILABLE_RECORDED
  ATTENDANCE_LEAVE_APPROVED
  ATTENDANCE_LEAVE_REJECTED
  ATTENDANCE_CORRECTED
  ATTENDANCE_STALE_REVIEW
  ATTENDANCE_OVERTIME_APPROVED
  ATTENDANCE_OVERTIME_REJECTED
  ATTENDANCE_HOLIDAY_UPDATED
  PAYROLL_FINALIZED
  PAYROLL_PAYMENT_UPDATED
  EMPLOYEE_PROFILE_UPDATED
  EMPLOYEE_LIFECYCLE_RECORDED
  ATTENDANCE_CORRECTION_REQUESTED
  ATTENDANCE_CORRECTION_APPROVED
  ATTENDANCE_CORRECTION_REJECTED
  TRANSPORT_OPTION_CREATED
  TRANSPORT_OPTION_UPDATED
  TRANSPORT_OPTION_DISABLED
  TRANSPORT_ASSIGNED
  DELIVERY_PROOF_UPLOADED
  DELIVERY_PROOF_ASSISTANCE_REQUESTED
  DELIVERY_PROOF_ASSISTANCE_CANCELLED
  DELIVERY_PROOF_ASSISTANCE_COMPLETED
  DELIVERY_PROOF_REPLACED
  ORDER_RECEIVED
  ORDER_RECEIVING_UPDATED
  PHYSICAL_TEAM_ASSIGNED
  PHYSICAL_CHECK_STARTED
  PHYSICAL_CHECK_COMPLETED
  PHYSICAL_CHECK_ISSUE_REPORTED
  QC_REWORK_REQUESTED
  QC_REWORK_COMPLETED
  QC_APPROVED
  INVENTORY_INQUIRY_CREATED
  INVENTORY_INQUIRY_UPDATED
  WORK_TEAM_CREATED
  WORK_TEAM_UPDATED
  WORK_TEAM_MEMBER_UPDATED
  WORK_TASK_CREATED
  WORK_TASK_UPDATED
  WORK_TASK_COMMENTED
  WORK_TASK_STATUS_CHANGED
  WORK_TASK_REMINDER_SWEEP
  FIELD_VISIT_CREATED
  FIELD_VISIT_UPDATED
  COLLECTION_CREATED
  COLLECTION_UPDATED
  COLLECTION_STATUS_CHANGED
  COLLECTION_PROOF_UPLOADED
  COLLECTION_VERIFIED
  ALERT_ACKNOWLEDGED
  ALERT_RESOLVED
  DAILY_ARCHIVE_GENERATED
  SUPPLIER_CREATED
  SUPPLIER_UPDATED
  SUPPLIER_ARCHIVED
  SUPPLIER_REACTIVATED
  PRODUCT_SUPPLIER_UPDATED
  PURCHASE_REQUEST_CREATED
  PURCHASE_REQUEST_SUBMITTED
  PURCHASE_REQUEST_APPROVED
  PURCHASE_REQUEST_REJECTED
  PURCHASE_REQUEST_ORDERED
  PURCHASE_REQUEST_IN_TRANSIT
  PURCHASE_REQUEST_CANCELLED
  PURCHASE_STOCK_RECEIVED
}

model User {
  id                 String       @id @default(cuid())
  name               String
  email              String       @unique
  phone              String?
  passwordHash       String?
  mustChangePassword Boolean      @default(false)
  role               UserRole
  status             UserStatus   @default(ACTIVE)
  geofenceMode       GeofenceMode @default(OFFICE_REQUIRED)
  archivedAt         DateTime?
  archivedById       String?
  archivedByName     String?
  exitReason         String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  dealerOrders                  Order[]                       @relation("DealerOrders")
  assignedDriverOrders          Order[]                       @relation("AssignedDriverOrders")
  receivedOrders                Order[]                       @relation("OrdersReceivedBy")
  authSessions                  AuthSession[]
  securityAuditLogs             SecurityAuditLog[]            @relation("SecurityAuditLogs")
  officeAttendanceRecords       OfficeAttendance[]            @relation("OfficeAttendanceUser")
  officeAttendanceEvents        OfficeAttendanceEvent[]       @relation("OfficeAttendanceEventUser")
  officeAttendanceAttempts      OfficeAttendanceAttempt[]     @relation("OfficeAttendanceAttemptUser")
  attendancePayProfile          AttendancePayProfile?         @relation("AttendancePayProfileUser")
  attendancePayProfilesSet      AttendancePayProfile[]        @relation("AttendancePayProfileUpdatedBy")
  attendanceAdvanceRequests     AttendanceAdvanceRequest[]    @relation("AttendanceAdvanceUser")
  attendanceAdvanceDecisions    AttendanceAdvanceRequest[]    @relation("AttendanceAdvanceDecidedBy")
  attendanceLeaveRequests       AttendanceLeaveRequest[]      @relation("AttendanceLeaveUser")
  attendanceLeaveDecisions      AttendanceLeaveRequest[]      @relation("AttendanceLeaveDecidedBy")
  stockBlocksCreated            StockBlockTimeline[]          @relation("StockBlockTimelineBlockedBy")
  stockBlocksReleased           StockBlockTimeline[]          @relation("StockBlockTimelineReleasedBy")
  transportOptionsCreated       TransportOption[]             @relation("TransportOptionCreatedBy")
  transportOptionsUpdated       TransportOption[]             @relation("TransportOptionUpdatedBy")
  deliveryProofsUploaded        DeliveryProof[]               @relation("DeliveryProofUploadedBy")
  deliveryProofsReplaced        DeliveryProof[]               @relation("DeliveryProofReplacedBy")
  deliveredOrders               Order[]                       @relation("OrdersDeliveredBy")
  deliveryProofRequests         Order[]                       @relation("DeliveryProofRequestedBy")
  deliveryProofCompletions      Order[]                       @relation("DeliveryProofCompletedBy")
  inventoryInquiriesCreated     InventoryInquiry[]            @relation("InventoryInquiryCreatedBy")
  fieldVisitsCreated            FieldVisit[]                  @relation("FieldVisitCreatedBy")
  workTeamsCreated              WorkTeam[]                    @relation("WorkTeamsCreated")
  workTeamsUpdated              WorkTeam[]                    @relation("WorkTeamsUpdated")
  workTeamMemberships           WorkTeamMember[]              @relation("WorkTeamMemberships")
  workTeamMembersAdded          WorkTeamMember[]              @relation("WorkTeamMembersAddedBy")
  workTasksAssigned             WorkTask[]                    @relation("WorkTasksAssigned")
  workTasksCreated              WorkTask[]                    @relation("WorkTasksCreated")
  workTaskComments              WorkTaskComment[]             @relation("WorkTaskCommentsCreatedBy")
  workTaskActivities            WorkTaskActivity[]            @relation("WorkTaskActivitiesCreatedBy")
  collectionTasksAssigned       CollectionAssignment[]        @relation("CollectionAssignmentAssignedTo")
  collectionTasksCreated        CollectionAssignment[]        @relation("CollectionAssignmentCreatedBy")
  collectionTasksDealer         CollectionAssignment[]        @relation("CollectionAssignmentDealer")
  collectionsCollected          CollectionAssignment[]        @relation("CollectionAssignmentCollectedBy")
  collectionsVerified           CollectionAssignment[]        @relation("CollectionAssignmentVerifiedBy")
  collectionProofsUploaded      CollectionProof[]             @relation("CollectionProofUploadedBy")
  notificationRecipients        NotificationRecipient[]       @relation("NotificationRecipients")
  notificationsAuthored         Notification[]                @relation("NotificationActor")
  physicalAssignmentsAssigned   OrderPhysicalAssignment[]     @relation("PhysicalAssignmentsAssignedBy")
  physicalAssignmentsStarted    OrderPhysicalAssignment[]     @relation("PhysicalAssignmentsStartedBy")
  physicalAssignmentsCompleted  OrderPhysicalAssignment[]     @relation("PhysicalAssignmentsCompletedBy")
  physicalAssignmentsQcRejected OrderPhysicalAssignment[]     @relation("PhysicalAssignmentsQcRejectedBy")
  physicalItemsChecked          OrderPhysicalAssignmentItem[] @relation("PhysicalAssignmentItemsCheckedBy")
  roleAssignments               UserRoleAssignment[]          @relation("UserRoleAssignments")
  roleAssignmentsCreated        UserRoleAssignment[]          @relation("UserRoleAssignmentsCreatedBy")
  dealerCart                    DealerCart?                   @relation("DealerCartOwner")
  dealerProfile                 DealerProfile?                @relation("DealerProfileOwner")
  employeeProfile                EmployeeProfile?              @relation("EmployeeProfileUser")
  reportingManagerProfiles       EmployeeProfile[]             @relation("EmployeeReportingManager")
  employeeLifecycleEvents        EmployeeLifecycleEvent[]      @relation("EmployeeLifecycleUser")
  employeeLifecycleEventsCreated EmployeeLifecycleEvent[]      @relation("EmployeeLifecycleCreatedBy")
  attendanceCorrectionRequests   AttendanceCorrectionRequest[] @relation("AttendanceCorrectionRequestUser")
  attendanceCorrectionDecisions  AttendanceCorrectionRequest[] @relation("AttendanceCorrectionRequestDecidedBy")
  payrollPaymentsMarked          PayrollRunItem[]              @relation("PayrollRunItemPaidBy")
}

model DealerProfile {
  id              String   @id @default(cuid())
  dealerId        String   @unique
  businessName    String
  contactPerson   String?
  gstNumber       String?  @unique
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  postalCode      String?
  creditLimit     Decimal  @default(0) @db.Decimal(14, 2)
  openingBalance  Decimal  @default(0) @db.Decimal(14, 2)
  internalNotes   String?
  createdById     String?
  createdByName   String?
  updatedById     String?
  updatedByName   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  dealer User @relation("DealerProfileOwner", fields: [dealerId], references: [id], onDelete: Cascade)

  @@index([businessName])
  @@index([city])
  @@index([state])
  @@index([updatedAt])
}

model UserRoleAssignment {
  id             String   @id @default(cuid())
  userId         String
  role           UserRole
  isPrimary      Boolean  @default(false)
  assignedById   String?
  assignedByName String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user       User  @relation("UserRoleAssignments", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy User? @relation("UserRoleAssignmentsCreatedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([userId, role])
  @@index([userId])
  @@index([role])
  @@index([isPrimary])
  @@index([assignedById])
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model DealerMember {
  id            String   @id @default(cuid())
  memberName    String
  dealerName    String
  contactNumber String
  createdById   String?
  createdByName String?
  updatedById   String?
  updatedByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([dealerName])
  @@index([contactNumber])
  @@index([createdAt])
}

model SecurityAuditLog {
  id          String            @id @default(cuid())
  eventType   SecurityEventType
  userId      String?
  userName    String?
  userEmail   String?
  userRole    String?
  path        String?
  ipAddress   String?
  userAgent   String?
  description String?
  createdAt   DateTime          @default(now())

  user User? @relation("SecurityAuditLogs", fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([userId])
  @@index([userEmail])
  @@index([createdAt])
}

model Notification {
  id               String   @id @default(cuid())
  title            String
  message          String
  module           String   @default("SYSTEM")
  href             String?
  priority         String   @default("NORMAL")
  status           String   @default("OPEN")
  dedupeKey        String?  @unique
  orderId          String?
  actorUserId      String?
  actorName        String?
  actorRole        String?
  acknowledgedAt   DateTime?
  acknowledgedById String?
  resolvedAt       DateTime?
  resolvedById     String?
  resolutionNote   String?
  escalatedAt      DateTime?
  expiresAt        DateTime?
  createdAt        DateTime @default(now())

  order      Order?                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor      User?                   @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  recipients NotificationRecipient[]

  @@index([module])
  @@index([priority])
  @@index([status])
  @@index([orderId])
  @@index([actorUserId])
  @@index([acknowledgedAt])
  @@index([resolvedAt])
  @@index([escalatedAt])
  @@index([expiresAt])
  @@index([createdAt])
}

model NotificationRecipient {
  id             String    @id @default(cuid())
  notificationId String
  userId         String?
  roleSnapshot   UserRole?
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User?        @relation("NotificationRecipients", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([notificationId])
  @@index([userId])
  @@index([roleSnapshot])
  @@index([readAt])
  @@index([createdAt])
}

model ProductCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([isActive])
  @@index([name])
}

model ProductBrand {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([isActive])
  @@index([name])
}

model Product {
  id             String        @id @default(cuid())
  code           String        @unique
  name           String
  description    String?
  categoryId     String
  brandId        String
  stack          String
  unit           String        @default("Sheets")
  gstRate        Decimal       @default(18) @db.Decimal(5, 2)
  purchasePrice  Decimal?      @db.Decimal(12, 2)
  sellingPrice   Decimal?      @db.Decimal(12, 2)
  dealerPrice    Decimal?      @db.Decimal(12, 2)
  imageData      Bytes?
  imageMimeType  String?
  imageFileName  String?
  quantity       Int
  blocked        Int           @default(0)
  minimumStock   Int           @default(0)
  maximumStock   Int           @default(0)
  status         ProductStatus @default(AVAILABLE)
  isActive       Boolean       @default(true)
  archivedAt     DateTime?     @db.Timestamptz(6)
  archivedById   String?
  archivedByName String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  category            ProductCategory      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brand               ProductBrand         @relation(fields: [brandId], references: [id], onDelete: Restrict)
  orderItems          OrderItem[]
  stockBlockTimelines StockBlockTimeline[]
  inventoryInquiries  InventoryInquiry[]
  dealerCartItems      DealerCartItem[]
  supplierLinks        ProductSupplier[]
  purchaseRequestItems PurchaseRequestItem[]
  purchaseReceiptItems PurchaseReceiptItem[]

  @@index([categoryId])
  @@index([brandId])
  @@index([status])
  @@index([isActive])
  @@index([minimumStock])
  @@index([maximumStock])
}


model DealerCart {
  id        String   @id @default(cuid())
  dealerId  String   @unique
  notes     String?
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dealer User             @relation("DealerCartOwner", fields: [dealerId], references: [id], onDelete: Cascade)
  items  DealerCartItem[]

  @@index([updatedAt])
}

model DealerCartItem {
  id                  String               @id @default(cuid())
  cartId              String
  productId           String
  quantity            Int
  unitPriceSnapshot   Decimal              @db.Decimal(12, 2)
  gstRateSnapshot     Decimal              @db.Decimal(5, 2)
  priceSourceSnapshot OrderItemPriceSource
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  cart    DealerCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product    @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
  @@index([updatedAt])
}

model Order {
  id                            String                        @id @default(cuid())
  orderNumber                   String                        @unique
  dealerId                      String
  assignedDriverId              String?
  transportOptionId             String?
  transportLabel                String?
  signedInvoiceStatus           String                        @default("NOT_UPLOADED")
  signedInvoiceUploadedAt       DateTime?
  deliveredById                 String?
  deliveredByName               String?
  deliveredAt                   DateTime?
  deliveryProofAssistanceStatus DeliveryProofAssistanceStatus @default(NOT_REQUESTED)
  deliveryProofRequestedById    String?
  deliveryProofRequestedByName  String?
  deliveryProofRequestedAt      DateTime?
  deliveryProofRequestNote      String?
  deliveryProofCompletedById    String?
  deliveryProofCompletedByName  String?
  deliveryProofCompletedAt      DateTime?
  receivedById                  String?
  receivedByName                String?
  receivedAt                    DateTime?
  receivingNotes                String?
  status                        OrderStatus                   @default(NEW_ORDER)
  source                        OrderSource                   @default(DEALER_PORTAL)
  enteredById                   String?
  enteredByName                 String?
  enteredByRole                 String?
  priority                      String                        @default("NORMAL")
  requiredBy                    DateTime?
  cancellationPreviousStatus    OrderStatus?
  cancellationRequestedAt       DateTime?
  cancellationRequestedById     String?
  cancellationRequestedByName   String?
  cancellationRequestReason     String?
  cancellationDecidedAt         DateTime?
  cancellationDecidedById       String?
  cancellationDecidedByName     String?
  cancellationDecisionReason    String?
  notes                         String?
  createdAt                     DateTime                      @default(now())
  updatedAt                     DateTime                      @updatedAt

  dealer                   User                      @relation("DealerOrders", fields: [dealerId], references: [id])
  assignedDriver           User?                     @relation("AssignedDriverOrders", fields: [assignedDriverId], references: [id])
  deliveredBy              User?                     @relation("OrdersDeliveredBy", fields: [deliveredById], references: [id], onDelete: SetNull)
  deliveryProofRequestedBy User?                     @relation("DeliveryProofRequestedBy", fields: [deliveryProofRequestedById], references: [id], onDelete: SetNull)
  deliveryProofCompletedBy User?                     @relation("DeliveryProofCompletedBy", fields: [deliveryProofCompletedById], references: [id], onDelete: SetNull)
  receivedBy               User?                     @relation("OrdersReceivedBy", fields: [receivedById], references: [id], onDelete: SetNull)
  transportOption          TransportOption?          @relation("OrderTransportOption", fields: [transportOptionId], references: [id], onDelete: SetNull)
  items                    OrderItem[]
  statusHistory            OrderStatusHistory[]
  stockBlockTimelines      StockBlockTimeline[]
  deliveryProofs           DeliveryProof[]
  notifications            Notification[]
  physicalAssignments      OrderPhysicalAssignment[]
  workflowTasks            WorkTask[]

  @@index([dealerId])
  @@index([assignedDriverId])
  @@index([deliveredById])
  @@index([deliveryProofAssistanceStatus])
  @@index([deliveryProofRequestedById])
  @@index([deliveryProofCompletedById])
  @@index([receivedById])
  @@index([receivedAt])
  @@index([transportOptionId])
  @@index([signedInvoiceStatus])
  @@index([status])
  @@index([source])
  @@index([priority])
  @@index([requiredBy])
  @@index([cancellationPreviousStatus])
  @@index([cancellationRequestedAt])
}

model OrderItem {
  id                String               @id @default(cuid())
  orderId           String
  productId         String
  requestedQuantity Int                  @default(0)
  quantity          Int
  blockedQuantity   Int                  @default(0)
  deliveredQuantity Int                  @default(0)
  cancelledQuantity Int                  @default(0)
  unitPrice         Decimal              @db.Decimal(12, 2)
  gstRate           Decimal              @db.Decimal(5, 2)
  lineSubtotal      Decimal              @db.Decimal(14, 2)
  taxAmount         Decimal              @db.Decimal(14, 2)
  lineTotal         Decimal              @db.Decimal(14, 2)
  priceSource       OrderItemPriceSource
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  order                  Order                        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product                Product                      @relation(fields: [productId], references: [id])
  stockBlockTimelines    StockBlockTimeline[]
  physicalAssignmentItem OrderPhysicalAssignmentItem?

  @@index([orderId])
  @@index([productId])
}

model OrderStatusHistory {
  id             String       @id @default(cuid())
  orderId        String
  fromStatus     OrderStatus?
  toStatus       OrderStatus
  title          String
  description    String?
  changedByName  String
  changedByEmail String
  changedByRole  String
  createdAt      DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

model OfficeLocation {
  id            String   @id @default(cuid())
  name          String   @default("Main Office")
  address       String?
  latitude      Float?
  longitude     Float?
  radiusMeters  Int      @default(200)
  isActive      Boolean  @default(true)
  updatedById   String?
  updatedByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model OfficeAttendance {
  id                     String    @id @default(cuid())
  userId                 String
  workDate               String
  status                 String    @default("PUNCHED_IN")
  punchInAt              DateTime?
  punchInLatitude        Float?
  punchInLongitude       Float?
  punchInAccuracyMeters  Float?
  punchInDistanceMeters  Float?
  punchInInsideGeofence  Boolean   @default(false)
  punchInPhotoDataUrl    String?
