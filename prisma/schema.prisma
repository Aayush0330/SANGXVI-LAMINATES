generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  MANAGER
  ACCOUNTANT
  INVENTORY_TEAM
  DISPATCH_TEAM
  QC_TEAM
  DRIVER_TRANSPORT
  COLLECTION_TEAM
  SALES_FIELD_TEAM
  DEALER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  AVAILABLE
  LOW_STOCK
  OUT_OF_STOCK
}

enum OrderStatus {
  NEW_ORDER
  STOCK_CHECKED
  STOCK_BLOCKED
  PARTIALLY_BLOCKED
  BACKORDERED
  READY_FOR_DISPATCH
  QC_APPROVED
  CANCELLATION_REQUESTED
  TRANSPORT_ASSIGNED
  ON_THE_WAY
  PARTIALLY_DELIVERED
  DELIVERED
  INVOICE_UPLOADED
  PARTIALLY_CANCELLED
  CANCELLED
}

enum SecurityEventType {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  ACCESS_DENIED
  PASSWORD_RESET
  PASSWORD_CHANGED
  FIRST_OWNER_CREATED
  OFFICE_LOCATION_UPDATED
  ATTENDANCE_PUNCH
  ATTENDANCE_BREAK
  ATTENDANCE_BLOCKED
  TRANSPORT_OPTION_CREATED
  TRANSPORT_OPTION_UPDATED
  TRANSPORT_OPTION_DISABLED
  TRANSPORT_ASSIGNED
  DELIVERY_PROOF_UPLOADED
}

model User {
  id                 String     @id @default(cuid())
  name               String
  email              String     @unique
  phone              String?
  passwordHash       String?
  mustChangePassword Boolean    @default(false)
  role               UserRole
  status             UserStatus @default(ACTIVE)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  dealerOrders             Order[]                   @relation("DealerOrders")
  assignedDriverOrders     Order[]                   @relation("AssignedDriverOrders")
  authSessions             AuthSession[]
  securityAuditLogs        SecurityAuditLog[]        @relation("SecurityAuditLogs")
  officeAttendanceRecords  OfficeAttendance[]        @relation("OfficeAttendanceUser")
  officeAttendanceEvents   OfficeAttendanceEvent[]   @relation("OfficeAttendanceEventUser")
  officeAttendanceAttempts OfficeAttendanceAttempt[] @relation("OfficeAttendanceAttemptUser")
  stockBlocksCreated       StockBlockTimeline[]      @relation("StockBlockTimelineBlockedBy")
  stockBlocksReleased      StockBlockTimeline[]      @relation("StockBlockTimelineReleasedBy")
  transportOptionsCreated  TransportOption[]         @relation("TransportOptionCreatedBy")
  transportOptionsUpdated  TransportOption[]         @relation("TransportOptionUpdatedBy")
  deliveryProofsUploaded   DeliveryProof[]           @relation("DeliveryProofUploadedBy")
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model SecurityAuditLog {
  id          String            @id @default(cuid())
  eventType   SecurityEventType
  userId      String?
  userName    String?
  userEmail   String?
  userRole    String?
  path        String?
  ipAddress   String?
  userAgent   String?
  description String?
  createdAt   DateTime          @default(now())

  user User? @relation("SecurityAuditLogs", fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([userId])
  @@index([userEmail])
  @@index([createdAt])
}

model Product {
  id           String        @id @default(cuid())
  code         String        @unique
  name         String
  stack        String
  quantity     Int
  blocked      Int           @default(0)
  minimumStock Int           @default(0)
  status       ProductStatus @default(AVAILABLE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  orderItems          OrderItem[]
  stockBlockTimelines StockBlockTimeline[]
}

model Order {
  id                      String      @id @default(cuid())
  orderNumber             String      @unique
  dealerId                String
  assignedDriverId        String?
  transportOptionId       String?
  transportLabel          String?
  signedInvoiceStatus     String      @default("NOT_UPLOADED")
  signedInvoiceUploadedAt DateTime?
  status                  OrderStatus @default(NEW_ORDER)
  notes                   String?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  dealer              User                 @relation("DealerOrders", fields: [dealerId], references: [id])
  assignedDriver      User?                @relation("AssignedDriverOrders", fields: [assignedDriverId], references: [id])
  transportOption     TransportOption?     @relation("OrderTransportOption", fields: [transportOptionId], references: [id], onDelete: SetNull)
  items               OrderItem[]
  statusHistory       OrderStatusHistory[]
  stockBlockTimelines StockBlockTimeline[]
  deliveryProofs      DeliveryProof[]

  @@index([dealerId])
  @@index([assignedDriverId])
  @@index([transportOptionId])
  @@index([signedInvoiceStatus])
  @@index([status])
}

model OrderItem {
  id                String   @id @default(cuid())
  orderId           String
  productId         String
  requestedQuantity Int      @default(0)
  quantity          Int
  blockedQuantity   Int      @default(0)
  deliveredQuantity Int      @default(0)
  cancelledQuantity Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  order               Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product             Product              @relation(fields: [productId], references: [id])
  stockBlockTimelines StockBlockTimeline[]

  @@index([orderId])
  @@index([productId])
}

model OrderStatusHistory {
  id             String       @id @default(cuid())
  orderId        String
  fromStatus     OrderStatus?
  toStatus       OrderStatus
  title          String
  description    String?
  changedByName  String
  changedByEmail String
  changedByRole  String
  createdAt      DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

model OfficeLocation {
  id            String   @id @default(cuid())
  name          String   @default("Main Office")
  address       String?
  latitude      Float?
  longitude     Float?
  radiusMeters  Int      @default(200)
  isActive      Boolean  @default(true)
  updatedById   String?
  updatedByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model OfficeAttendance {
  id                     String    @id @default(cuid())
  userId                 String
  workDate               String
  status                 String    @default("PUNCHED_IN")
  punchInAt              DateTime?
  punchInLatitude        Float?
  punchInLongitude       Float?
  punchInAccuracyMeters  Float?
  punchInDistanceMeters  Float?
  punchInInsideGeofence  Boolean   @default(false)
  punchInPhotoDataUrl    String?
  punchOutAt             DateTime?
  punchOutLatitude       Float?
  punchOutLongitude      Float?
  punchOutAccuracyMeters Float?
  punchOutDistanceMeters Float?
  punchOutInsideGeofence Boolean   @default(false)
  punchOutPhotoDataUrl   String?
  currentBreakType       String?
  currentBreakStartedAt  DateTime?
  breakMinutes           Int       @default(0)
  totalMinutes           Int?
  netWorkingMinutes      Int?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user   User                    @relation("OfficeAttendanceUser", fields: [userId], references: [id], onDelete: Cascade)
  events OfficeAttendanceEvent[] @relation("OfficeAttendanceEvents")

  @@unique([userId, workDate])
  @@index([workDate])
  @@index([userId])
  @@index([status])
}

model OfficeAttendanceEvent {
  id             String   @id @default(cuid())
  attendanceId   String
  userId         String
  eventType      String
  label          String
  latitude       Float?
  longitude      Float?
  accuracyMeters Float?
  distanceMeters Float?
  insideGeofence Boolean  @default(false)
  photoDataUrl   String?
  note           String?
  createdAt      DateTime @default(now())

  attendance OfficeAttendance @relation("OfficeAttendanceEvents", fields: [attendanceId], references: [id], onDelete: Cascade)
  user       User             @relation("OfficeAttendanceEventUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([attendanceId])
  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}

model OfficeAttendanceAttempt {
  id             String   @id @default(cuid())
  userId         String
  actionType     String
  status         String
  message        String?
  latitude       Float?
  longitude      Float?
  accuracyMeters Float?
  distanceMeters Float?
  insideGeofence Boolean  @default(false)
  photoDataUrl   String?
  attemptedAt    DateTime @default(now())

  user User @relation("OfficeAttendanceAttemptUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([actionType])
  @@index([status])
  @@index([attemptedAt])
}

model StockBlockTimeline {
  id              String    @id @default(cuid())
  productId       String
  orderId         String
  orderItemId     String
  quantity        Int
  status          String    @default("ACTIVE")
  blockReason     String    @default("ORDER_STOCK_BLOCKED")
  releaseReason   String?
  blockedAt       DateTime  @default(now()) @db.Timestamptz(6)
  blockedUntil    DateTime? @db.Timestamptz(6)
  releasedAt      DateTime? @db.Timestamptz(6)
  blockedById     String?
  blockedByName   String?
  blockedByEmail  String?
  releasedById    String?
  releasedByName  String?
  releasedByEmail String?
  notes           String?
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem  OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  blockedBy  User?     @relation("StockBlockTimelineBlockedBy", fields: [blockedById], references: [id], onDelete: SetNull)
  releasedBy User?     @relation("StockBlockTimelineReleasedBy", fields: [releasedById], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([orderId])
  @@index([orderItemId])
  @@index([status])
  @@index([blockedAt])
  @@index([releasedAt])
}

model TransportOption {
  id            String   @id @default(cuid())
  name          String   @unique
  description   String?
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdById   String?
  updatedById   String?
  createdByName String?
  updatedByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdBy User?   @relation("TransportOptionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?   @relation("TransportOptionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  orders    Order[] @relation("OrderTransportOption")

  @@index([isActive])
  @@index([sortOrder])
}

model DeliveryProof {
  id           String   @id @default(cuid())
  orderId      String
  uploadedById String?
  proofType    String   @default("SIGNED_DUPLICATE_INVOICE")
  fileName     String
  mimeType     String
  fileDataUrl  String
  note         String?
  uploadedAt   DateTime @default(now())

  order      Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  uploadedBy User? @relation("DeliveryProofUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([uploadedById])
  @@index([proofType])
  @@index([uploadedAt])
}
