  parentTask WorkTask?          @relation("WorkTaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subTasks   WorkTask[]         @relation("WorkTaskHierarchy")
  order      Order?             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  comments   WorkTaskComment[]
  activities WorkTaskActivity[]

  @@index([teamId])
  @@index([assigneeId])
  @@index([createdById])
  @@index([parentTaskId])
  @@index([orderId])
  @@index([isAutomated])
  @@index([workflowStage])
  @@index([sourceEvent])
  @@index([workflowPauseReason])
  @@index([status])
  @@index([priority])
  @@index([taskType])
  @@index([dueAt])
  @@index([relatedModule])
  @@index([calendarStatus])
  @@index([calendarReminderAt])
  @@index([calendarSyncedAt])
  @@index([calendarReminderSentAt])
  @@index([dueReminderSentAt])
  @@index([overdueReminderSentAt])
  @@index([lastReviewedAt])
  @@index([reviewedById])
  @@index([createdAt])
}

model WorkTaskComment {
  id          String   @id @default(cuid())
  taskId      String
  createdById String?
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  task      WorkTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("WorkTaskCommentsCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([createdById])
  @@index([createdAt])
}

model WorkTaskActivity {
  id        String   @id @default(cuid())
  taskId    String
  actorId   String?
  eventType String
  message   String
  createdAt DateTime @default(now())

  task  WorkTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User?    @relation("WorkTaskActivitiesCreatedBy", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([actorId])
  @@index([eventType])
  @@index([createdAt])
}

model BackupRecord {
  id             String   @id @default(cuid())
  kind           String   @default("MANUAL")
  status         String   @default("RUNNING")
  fileName       String?
  filePath       String?
  sizeBytes      BigInt?
  sha256         String?
  manifestPath   String?
  retentionDays  Int?
  triggeredById  String?
  triggeredBy    String?
  errorMessage   String?
  startedAt      DateTime @default(now())
  completedAt    DateTime?
  verifiedAt     DateTime?
  createdAt      DateTime @default(now())

  @@index([kind])
  @@index([status])
  @@index([startedAt])
  @@index([completedAt])
  @@index([verifiedAt])
}

model RestoreAudit {
  id             String   @id @default(cuid())
  backupRecordId String?
  fileName       String
  filePath       String
  sha256         String?
  status         String   @default("STARTED")
  triggeredById  String?
  triggeredBy    String?
  errorMessage   String?
  startedAt      DateTime @default(now())
  completedAt    DateTime?
  createdAt      DateTime @default(now())

  @@index([backupRecordId])
  @@index([status])
  @@index([startedAt])
}

model DailyBusinessArchive {
  id            String   @id @default(cuid())
  businessDate  DateTime @unique @db.Date
  status        String   @default("GENERATING")
  fileName      String?
  filePath      String?
  sha256        String?
  summary       Json?
  errorMessage  String?
  generatedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([generatedAt])
}



model Supplier {
  id                  String   @id @default(cuid())
  code                String   @unique
  companyName         String
  contactPerson       String?
  phone               String?
  email               String?
  gstNumber           String?  @unique
  addressLine1        String?
  addressLine2        String?
  city                String?
  state               String?
  postalCode          String?
  paymentTerms        String?
  defaultLeadTimeDays Int      @default(0)
  internalNotes       String?
  isActive            Boolean  @default(true)
  archivedAt          DateTime?
  archivedById        String?
  archivedByName      String?
  createdById         String?
  createdByName       String?
  updatedById         String?
  updatedByName       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  productLinks     ProductSupplier[]
  purchaseRequests PurchaseRequest[]

  @@index([companyName])
  @@index([isActive])
  @@index([city])
  @@index([state])
  @@index([updatedAt])
}

model ProductSupplier {
  id                   String   @id @default(cuid())
  productId            String
  supplierId           String
  supplierProductCode  String?
  isPreferred          Boolean  @default(false)
  minimumOrderQuantity Int      @default(1)
  lastPurchasePrice    Decimal? @db.Decimal(12, 2)
  leadTimeDays         Int?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([productId, supplierId])
  @@index([productId])
  @@index([supplierId])
  @@index([isPreferred])
  @@index([isActive])
}

model PurchaseRequest {
  id                    String                  @id @default(cuid())
  requestNumber         String                  @unique
  supplierId            String
  status                PurchaseRequestStatus   @default(SUBMITTED)
  priority              PurchaseRequestPriority @default(NORMAL)
  requestedById         String?
  requestedByName       String?
  requestedByRole       String?
  submittedAt           DateTime?
  approvedById          String?
  approvedByName        String?
  approvedAt            DateTime?
  rejectedById          String?
  rejectedByName        String?
  rejectedAt            DateTime?
  rejectionReason       String?
  cancelledById         String?
  cancelledByName       String?
  cancelledAt           DateTime?
  cancellationReason    String?
  orderedById           String?
  orderedByName         String?
  orderedAt             DateTime?
  purchaseOrderNumber   String?                 @unique
  inTransitAt           DateTime?
  expectedDeliveryDate  DateTime?
  actualDeliveryDate    DateTime?
  supplierInvoiceNumber String?
  notes                 String?
  estimatedTotal        Decimal                 @default(0) @db.Decimal(14, 2)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  supplier Supplier              @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items    PurchaseRequestItem[]
  receipts PurchaseReceipt[]

  @@index([supplierId])
  @@index([status])
  @@index([priority])
  @@index([expectedDeliveryDate])
  @@index([createdAt])
}

model PurchaseRequestItem {
  id                String   @id @default(cuid())
  purchaseRequestId String
  productId         String
  requestedQuantity Int
  approvedQuantity  Int      @default(0)
  orderedQuantity   Int      @default(0)
  receivedQuantity  Int      @default(0)
  damagedQuantity   Int      @default(0)
  rejectedQuantity  Int      @default(0)
  estimatedUnitPrice Decimal @default(0) @db.Decimal(12, 2)
  lineTotal         Decimal  @default(0) @db.Decimal(14, 2)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  product         Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  receiptItems    PurchaseReceiptItem[]

  @@unique([purchaseRequestId, productId])
  @@index([purchaseRequestId])
  @@index([productId])
}

model PurchaseReceipt {
  id                       String   @id @default(cuid())
  receiptNumber            String   @unique
  purchaseRequestId        String
  supplierInvoiceReference String?
  challanReference         String?
  receivedById             String?
  receivedByName           String?
  receivedAt               DateTime @default(now())
  notes                    String?
  createdAt                DateTime @default(now())

  purchaseRequest PurchaseRequest      @relation(fields: [purchaseRequestId], references: [id], onDelete: Restrict)
  items           PurchaseReceiptItem[]

  @@index([purchaseRequestId])
  @@index([receivedAt])
}

model PurchaseReceiptItem {
  id                    String   @id @default(cuid())
  purchaseReceiptId     String
  purchaseRequestItemId String
  productId             String
  receivedQuantity      Int
  acceptedQuantity      Int
  damagedQuantity       Int      @default(0)
  rejectedQuantity      Int      @default(0)
  unitCost              Decimal? @db.Decimal(12, 2)
  notes                 String?
  createdAt             DateTime @default(now())

  purchaseReceipt     PurchaseReceipt     @relation(fields: [purchaseReceiptId], references: [id], onDelete: Cascade)
  purchaseRequestItem PurchaseRequestItem @relation(fields: [purchaseRequestItemId], references: [id], onDelete: Restrict)
  product             Product             @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([purchaseReceiptId])
  @@index([purchaseRequestItemId])
  @@index([productId])
}
