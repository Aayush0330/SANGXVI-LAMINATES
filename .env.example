# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=disable"
DATABASE_POOL_MAX="4"
DATABASE_CONNECTION_TIMEOUT_MS="15000"
DATABASE_IDLE_TIMEOUT_MS="30000"
SEED_INITIAL_PASSWORD=""
INITIAL_USER_PASSWORD=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
SESSION_SECRET="change_this_to_a_strong_random_secret"

# Google Calendar
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""
GOOGLE_CALENDAR_REFRESH_TOKEN=""
GOOGLE_CALENDAR_ID="primary"

# Cron / Internal Jobs
CRON_SECRET="change_this_to_a_strong_random_secret"
RESTORE_CONFIRMATION_TOKEN="change_this_to_a_different_24_plus_character_secret"

# WhatsApp Cloud API
WHATSAPP_NOTIFICATIONS_ENABLED="false"
WHATSAPP_MESSAGE_MODE="text"
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_GRAPH_API_VERSION="v23.0"
WHATSAPP_DEFAULT_COUNTRY_CODE="91"
WHATSAPP_TEMPLATE_NAME=""
WHATSAPP_TEMPLATE_LANGUAGE="en"

# Database Backup
# Web download uses BACKUP_DATABASE_URL/DATABASE_URL and sends the generated
# .sql.gz directly to the browser. BACKUP_DIR is only for npm run db:backup.
BACKUP_DATABASE_URL=""
BACKUP_DIR="backups/database"
BACKUP_RETENTION_DAYS="30"
PG_DUMP_PATH="pg_dump"
PSQL_PATH="psql"
PRISMA_DEV_NAME="default"
